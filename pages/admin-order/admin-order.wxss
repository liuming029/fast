.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #3AAE6E 0%, #42ca7f 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.order-list {
  padding: 20rpx 30rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-number {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: #fff3cd;
  color: #856404;
}

.status-delivering {
  background: #cce5ff;
  color: #004085;
}

.status-completed {
  background: #d4edda;
  color: #155724;
}

.status-cancelled {
  background: #f8d7da;
  color: #721c24;
}

.order-address {
  display: flex;
  margin-bottom: 12rpx;
}

.order-address-label {
  font-size: 26rpx;
  color: #999;
  width: 100rpx;
}

.order-address-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #3AAE6E;
}

.order-commission {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.commission-label {
  font-size: 24rpx;
  color: #666;
}

.commission-value {
  font-size: 28rpx;
  font-weight: bold;
}

.commission-value.rider {
  color: #3AAE6E;
}

.commission-value.platform {
  color: #4A90E2;
}

.order-footer-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.delete-btn {
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}