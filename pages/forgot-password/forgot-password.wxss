.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #2dd9cc 0%, #1ac7ba 100%);
  position: relative;
  overflow: hidden;
}

.top-wave {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 300rpx;
  background: white;
  border-bottom-left-radius: 100rpx;
  border-bottom-right-radius: 100rpx;
}

.content {
  position: relative;
  z-index: 1;
  padding: 80rpx 48rpx 48rpx;
}

.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-box {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #2dd9cc 0%, #1ac7ba 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(45, 217, 204, 0.4);
}

.logo-emoji {
  font-size: 72rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.form-section {
  margin-top: 40rpx;
}

.form-card {
  background: white;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.form-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.form-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.form-subtitle {
  font-size: 28rpx;
  color: #999999;
  display: block;
}

.input-group {
  margin-bottom: 40rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-item:focus-within {
  background: white;
  border-color: #2dd9cc;
  box-shadow: 0 0 0 4rpx rgba(45, 217, 204, 0.1);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(90deg, #2dd9cc 0%, #1ac7ba 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 32rpx;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(45, 217, 204, 0.4);
  margin-bottom: 32rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
}

.register-link {
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.link-text {
  font-size: 28rpx;
  color: #999999;
}

.link-action {
  font-size: 28rpx;
  color: #2dd9cc;
  font-weight: 500;
}
