<view class="container">
  <view class="top-wave"></view>
  
  <view class="content">
    <view class="logo-section">
      <view class="logo-box">
        <text class="logo-emoji">📦</text>
      </view>
      <view class="app-name">快递代取</view>
      <view class="app-slogan">重置密码</view>
    </view>

    <view class="form-section">
      <view class="form-card">
        <view class="form-header">
          <text class="form-title">重置密码</text>
          <text class="form-subtitle">请输入您的账号和新密码</text>
        </view>

        <view class="input-group">
          <view class="input-item">
            <text class="input-icon">👤</text>
            <input 
              class="input-field" 
              placeholder="请输入用户名" 
              bindinput="onUsernameInput"
              value="{{username}}"
            />
          </view>

          <view class="input-item">
            <text class="input-icon">🔒</text>
            <input 
              class="input-field" 
              placeholder="请输入新密码" 
              password 
              bindinput="onPasswordInput"
              value="{{password}}"
            />
          </view>

          <view class="input-item">
            <text class="input-icon">🔐</text>
            <input 
              class="input-field" 
              placeholder="请再次输入新密码" 
              password 
              bindinput="onConfirmPasswordInput"
              value="{{confirmPassword}}"
            />
          </view>
        </view>

        <button class="submit-btn" bindtap="onResetPassword">
          重置密码
        </button>

        <view class="register-link">
          <text class="link-text">想起密码了？</text>
          <text class="link-action" bindtap="goToLogin">立即登录</text>
        </view>
      </view>
    </view>
  </view>
</view>