.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.app-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.version {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.info-card {
  margin: 30rpx 30rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.card-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.menu-list {
  margin: 30rpx 30rpx 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.3s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f5f5f5;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.footer {
  margin-top: 60rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
