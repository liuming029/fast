.container {
  min-height: 100vh;
  background: #f5f7fa;
}

.header {
  background: #2dd9cc;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  font-size: 48rpx;
  color: white;
  width: 80rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.content {
  padding: 40rpx 32rpx;
}

.notice-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.notice-time {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.notice-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.8;
}
