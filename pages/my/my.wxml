<view class="container">
  <view class="header">
    <view class="avatar">
      <image src="{{avatar || ''}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <view class="nickname">{{userInfo.userName || '用户'}}</view>
      <view class="user-id">ID: {{userInfo.userId || ''}}</view>
    </view>
  </view>

  <view class="balance-card" bindtap="goToRecharge">
    <view class="balance-label">账户余额</view>
    <view class="balance-amount">
      <text class="symbol">¥</text>
      <text class="number">{{balanceFormatted}}</text>
    </view>
    <view class="recharge-tip">点击充值</view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrders">
      <view class="menu-icon">📋</view>
      <view class="menu-text">我的订单</view>
      <view class="menu-arrow">></view>
    </view>
    
    <view class="menu-item" bindtap="{{isRider ? 'goToRiderHome' : 'goToRiderAuth'}}">
      <view class="menu-icon">🚴</view>
      <view class="menu-text">{{isRider ? '骑手工作台' : '骑手认证'}}</view>
      <view class="menu-arrow">></view>
    </view>
    
    <view class="menu-item" bindtap="goToAdminHome" wx:if="{{isAdmin}}">
      <view class="menu-icon">⚙️</view>
      <view class="menu-text">管理后台</view>
      <view class="menu-arrow">></view>
    </view>
    
    <view class="menu-item" bindtap="goToProfile">
      <view class="menu-icon">👤</view>
      <view class="menu-text">个人资料</view>
      <view class="menu-arrow">></view>
    </view>
    
    <view class="menu-item" bindtap="goToAbout">
      <view class="menu-icon">ℹ️</view>
      <view class="menu-text">关于我们</view>
      <view class="menu-arrow">></view>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">退出登录</view>
</view>