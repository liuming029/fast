.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #3AAE6E 0%, #42ca7f 100%);
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  margin-right: 30rpx;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
  color: #fff;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  opacity: 0.9;
}

.balance-card {
  background: #fff;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.balance-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.balance-amount {
  font-size: 56rpx;
  font-weight: bold;
  color: #3AAE6E;
}

.balance-amount .symbol {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.recharge-tip {
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #3AAE6E;
  border: 2rpx solid #3AAE6E;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
}

.menu-list {
  background: #fff;
  margin: 0 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 30rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 30rpx;
  color: #ccc;
}

.logout-btn {
  margin: 60rpx 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  color: #ff4d4f;
}