<view class="container">
  <view class="header">
    <view class="balance-label">当前余额</view>
    <view class="balance-amount">
      <text class="symbol">¥</text>
      <text class="number">{{balanceFormatted}}</text>
    </view>
  </view>

  <view class="amount-section">
    <view class="section-title">充值金额</view>
    <view class="amount-grid">
      <view class="amount-item {{selectedAmount === item ? 'active' : ''}}" 
            wx:for="{{presetAmounts}}" 
            wx:key="*this"
            bindtap="selectPreset"
            data-amount="{{item}}">
        <text class="val">{{item}}元</text>
      </view>
    </view>
  </view>

  <view class="submit-section">
    <view class="total-text">
      实付金额: <text class="price">¥{{selectedAmountFormatted}}</text>
    </view>
    <button class="submit-btn" bindtap="handleRecharge" loading="{{loading}}">
      立即充值
    </button>
  </view>
</view>