<view class="container">
  <view class="top-wave"></view>
  
  <view class="content">
    <view class="logo-section">
      <view class="logo-box">
        <text class="logo-emoji">📦</text>
      </view>
      <view class="app-name">快递代取</view>
      <view class="app-slogan">便捷生活，从这里开始</view>
    </view>

    <view class="form-section">
      <view class="form-card">
        <view class="form-header">
          <text class="form-title">创建账号</text>
          <text class="form-subtitle">请填写注册信息</text>
        </view>

        <view class="input-group">
          <view class="input-item">
            <text class="input-icon">👤</text>
            <input 
              class="input-field" 
              placeholder="请输入用户名（2-20位）" 
              bindinput="onUsernameInput"
              value="{{username}}"
            />
          </view>

          <view class="input-item">
            <text class="input-icon">🔒</text>
            <input 
              class="input-field" 
              placeholder="请输入密码（5-20位）" 
              password 
              bindinput="onPasswordInput"
              value="{{password}}"
            />
          </view>

          <view class="input-item">
            <text class="input-icon">🔒</text>
            <input 
              class="input-field" 
              placeholder="请再次输入密码" 
              password 
              bindinput="onConfirmPasswordInput"
              value="{{confirmPassword}}"
            />
          </view>
        </view>

        <button class="submit-btn" bindtap="onRegister">
          注册
        </button>

        <view class="register-link">
          <text class="link-text">已有账号？</text>
          <text class="link-action" bindtap="goToLogin">立即登录</text>
        </view>
      </view>
    </view>
  </view>
</view>