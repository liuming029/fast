.container {
  min-height: 100vh;
  background: #f5f7fa;
  position: relative;
  overflow: hidden;
}

.top-wave {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border-bottom-left-radius: 80rpx;
  border-bottom-right-radius: 80rpx;
  z-index: 0;
}

.content {
  position: relative;
  z-index: 1;
  padding: 80rpx 40rpx 40rpx;
}

.logo-section {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.logo-box {
  width: 160rpx;
  height: 160rpx;
  background: white;
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(79, 172, 254, 0.3);
}

.logo-emoji {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 300;
}

.form-section {
  margin-top: 20rpx;
}

.form-card {
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.form-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.form-subtitle {
  font-size: 28rpx;
  color: #999;
}

.input-group {
  margin-bottom: 48rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
  border: none;
  border-radius: 60rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.4);
  transition: all 0.3s ease;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(79, 172, 254, 0.3);
}

.register-link {
  text-align: center;
  margin-top: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.link-text {
  font-size: 28rpx;
  color: #999;
}

.link-action {
  font-size: 28rpx;
  color: #4facfe;
  font-weight: 600;
}
