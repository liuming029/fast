.container {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

.hero-section {
  position: relative;
  width: 100%;
  height: 520rpx;
}

.hero-bg {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to top, #ffffff, transparent);
}

.content-section {
  flex: 1;
  padding: 0;
  margin-top: -120rpx;
  position: relative;
  z-index: 1;
  background: #ffffff;
}

.order-card {
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 56rpx 48rpx 32rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.header-dot {
  width: 20rpx;
  height: 20rpx;
  background: #2dd9cc;
  border-radius: 50%;
  margin-right: 20rpx;
}

.card-title {
  font-size: 38rpx;
  font-weight: 500;
  color: #333333;
}

.select-section {
  margin-bottom: 32rpx;
}

.select-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.select-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.station-dot {
  background: #2dd9cc;
}

.building-dot {
  background: #ff936d;
}

.select-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.select-label {
  font-size: 26rpx;
  color: #999999;
}

.select-value {
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
}

.select-arrow {
  font-size: 48rpx;
  color: #cccccc;
  font-weight: 300;
}

.order-btn {
  width: 100%;
  background: #2dd9cc;
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 36rpx;
  font-size: 38rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.order-btn::after {
  border: none;
}

.links-section {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 0;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin: 0 -48rpx;
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.link-item {
  font-size: 28rpx;
  color: #999999;
}

.link-divider {
  width: 2rpx;
  height: 28rpx;
  background: #e8e8e8;
}

.notice-section {
  position: relative;
  z-index: 2;
  margin-top: -60rpx;
  padding: 0 24rpx;
}

.notice-bar {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.notice-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.notice-list {
  flex: 1;
  max-height: 200rpx;
  overflow-y: auto;
}

.notice-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-item:active {
  background: #f8f9fa;
}

.notice-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.rider-section,
.admin-section {
  flex: 1;
  padding: 0;
  margin-top: -120rpx;
  position: relative;
  z-index: 1;
  background: #ffffff;
}

.rider-card,
.admin-card {
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 56rpx 48rpx 32rpx;
}

.rider-header,
.admin-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.rider-icon,
.admin-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.rider-title,
.admin-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.rider-desc,
.admin-desc {
  font-size: 28rpx;
  color: #999999;
}

.rider-stats,
.admin-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 48rpx;
  padding: 32rpx 0;
  background: #f8f9fa;
  border-radius: 24rpx;
}

.rider-stat,
.admin-stat {
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #2dd9cc;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #666666;
}

.rider-btn,
.admin-btn {
  width: 100%;
  background: linear-gradient(90deg, #2dd9cc 0%, #1ac7ba 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 36rpx;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(45, 217, 204, 0.4);
}

.rider-btn::after,
.admin-btn::after {
  border: none;
}
