<view class="container">
  <view class="bg-section"></view>
  
  <view class="content">
    <view class="logo-circle">
      <text class="logo-emoji">📦</text>
    </view>
    
    <view class="login-card">
      <view class="card-header">
        <text class="hi-text">Hi~</text>
      </view>

      <view class="input-group">
        <view class="input-item">
          <text class="input-icon">👤</text>
          <input 
            class="input-field" 
            placeholder="请输入用户名" 
            bindinput="onUsernameInput"
            value="{{username}}"
          />
        </view>

        <view class="input-item">
          <text class="input-icon">🔒</text>
          <input 
            class="input-field" 
            placeholder="请输入密码" 
            password 
            bindinput="onPasswordInput"
            value="{{password}}"
          />
        </view>
      </view>

      <view class="links-section">
        <text class="link-left" bindtap="goToRegister">注册账号</text>
        <text class="link-right" bindtap="goToForgotPassword">忘记密码</text>
      </view>

      <button class="submit-btn" bindtap="onLogin">
        登录
      </button>
    </view>
  </view>
</view>