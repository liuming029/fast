<view class="container">
  <view class="top-wave"></view>
  
  <view class="content">
    <view class="logo-section">
      <view class="logo-box">
        <text class="logo-emoji">📦</text>
      </view>
      <view class="app-name">快递代取</view>
      <view class="app-slogan">便捷生活，从这里开始</view>
    </view>

    <view class="form-section">
      <view class="form-card">
        <view class="form-header">
          <text class="form-title">欢迎回来</text>
          <text class="form-subtitle">请登录您的账号</text>
        </view>

        <view class="input-group">
          <view class="input-item">
            <text class="input-icon">👤</text>
            <input 
              class="input-field" 
              placeholder="请输入用户名" 
              bindinput="onUsernameInput"
              value="{{username}}"
            />
          </view>

          <view class="input-item">
            <text class="input-icon">🔒</text>
            <input 
              class="input-field" 
              placeholder="请输入密码" 
              password 
              bindinput="onPasswordInput"
              value="{{password}}"
            />
          </view>
        </view>

        <button class="submit-btn" bindtap="onLogin">
          登录
        </button>

        <view class="forgot-link">
          <text class="link-action" bindtap="goToForgotPassword">忘记密码？</text>
        </view>

        <view class="register-link">
          <text class="link-text">还没有账号？</text>
          <text class="link-action" bindtap="goToRegister">立即注册</text>
        </view>
      </view>
    </view>
  </view>
</view>