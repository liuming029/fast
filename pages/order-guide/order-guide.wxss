.container {
  min-height: 100vh;
  background: #f5f7fa;
}

.header {
  background: #2dd9cc;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-btn {
  font-size: 48rpx;
  color: white;
  width: 80rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.content {
  padding: 32rpx 24rpx;
}

.guide-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.guide-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 32rpx;
}

.guide-step {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.guide-step:last-child {
  border-bottom: none;
}

.step-num {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #2dd9cc 0%, #1ac7ba 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999999;
}

.guide-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 2;
}
